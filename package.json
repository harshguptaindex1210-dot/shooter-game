{
  "name": "shooter-game",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/bundle-size.js",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "bench:render": "node scripts/bench-render.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/three": "^0.185.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jsdom": "^24.1.0",
    "prettier": "^3.3.2",
    "puppeteer": "^22.12.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.3",
    "vitest": "^2.0.2"
  },
  "dependencies": {
    "three": "^0.166.1"
  }
}
